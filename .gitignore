# Python virtual environment
venv/

# Training dataset (download from Kaggle — see README §9.4)
data/

# Next.js build artifacts
nextjs/node_modules/
nextjs/.next/
nextjs/tsconfig.tsbuildinfo

# Environment variables (never commit secrets)
.env.local

# SQLite database — auto-generated by database/init_db.py
database/*.db
database/*.db-wal
database/*.db-shm

# Trained model checkpoint — generate via notebooks/02_training.ipynb (see README §9.6)
models/*.pth

# Generated notebook output images — regenerated by running the notebooks
outputs/

# Runtime user-uploaded images
uploads/

# Python cache
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# OS artifacts
.DS_Store
Thumbs.db
